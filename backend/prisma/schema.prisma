generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DocumentStatus {
  APPROVED
  PENDING
  DECLINED
}

model User {
  id               String                   @id @default(cuid())
  name             String
  email            String                   @unique
  phoneNumber      String?                  @unique
  gender           Gender?
  address          String?
  city             String?
  country          String?
  occupation       String                   @default("Lawyer")
  status           UserStatus               @default(INACTIVE)
  role             Role                     @default(MEMBER)
  passwordHash     String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  resetTokens      PasswordResetToken[]
  activationTokens AccountActivationToken[]
  documents        UserDocument[]
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountActivationToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserDocument {
  id           String         @id @default(cuid())
  documentName String
  documentFile String
  status       DocumentStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Room {
  id          String   @id @default(cuid())
  name        String   @unique
  capacity    Int
  description String?
  imageUrl    String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // This will connect to bookings later when David adds his model
  // bookings Booking[]
}