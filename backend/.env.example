PORT=3000
DATABASE_URL="postgresql://username:password@localhost:5432/drhub_db?schema=public"
JWT_SECRET="replace-with-strong-random-secret"
JWT_EXPIRES_IN="7d"
RESET_TOKEN_EXPIRES_MINUTES=15
ACTIVATION_TOKEN_EXPIRES_HOURS=24
BACKEND_PUBLIC_URL="https://drhubbackend-6cucc.ondigitalocean.app"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="DRHub <no-reply@example.com>"

# Google Reviews API (for live reviews on client dashboard)
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Places API
# 3. Create an API key and restrict it to your domain(s)
# 4. Get your place ID from the Google Maps listing or Place ID Finder
# 5. Add these to your .env file
GOOGLE_PLACES_API_KEY="your-google-places-api-key-here"
GOOGLE_PLACE_ID="your-google-maps-place-id-here"
